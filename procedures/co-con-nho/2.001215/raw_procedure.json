    "description": "",
    "name": "Đăng ký phương tiện hoạt động vui chơi, giải trí dưới nước lần đầu",
    "decisionNo": "",
    "executionCases": [
      {
        "name": "-  Giấy tờ phải xuất trình khi nộp hồ sơ gồm bản chính các loại sau:",
        "profileComponents": [
          {
            "profileComponentId": "019d2bb8-71bc-74dd-9d15-730278256795",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "isProcessingResult": false,
            "name": "+  Giấy chứng nhận an toàn kỹ thuật và bảo vệ môi trường của phương tiện còn hiệu lực đối với phương tiện thuộc diện đăng kiểm;",
            "code": "000.00.00.G04-KQ004637",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71bc-74dd-9d15-74f015a1148e",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "isProcessingResult": false,
            "name": "+ Giấy phép hoặc tờ khai phương tiện nhập khẩu theo quy định của pháp luật đối với phương tiện được nhập khẩu;",
            "code": "000.00.00.G04-KQ004638",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71bc-74dd-9d15-7b0255756e7f",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "isProcessingResult": false,
            "name": "+ Giấy tờ chứng minh quyền sở hữu phương tiện: Hợp đồng mua bán hoặc hợp đồng đóng mới phương tiện hoặc các giấy tờ khác có giá trị tương đương;",
            "code": "000.00.00.G04-KQ004639",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71bc-74dd-9d15-83b0a747ee45",
            "originalQty": 0,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "isProcessingResult": false,
            "name": "(Trường hợp chủ phương tiện đồng thời là chủ cơ sở đóng mới, hoán cải, sửa chữa và phục hồi phương tiện được phép hoạt động theo quy định của pháp luật, khi thực hiện đăng ký phương tiện không phải xuất trình Giấy tờ chứng minh quyền sở hữu phương tiện: Hợp đồng mua bán hoặc hợp đồng đóng mới phương tiện hoặc các giấy tờ khác có giá trị tương đương).",
            "code": "000.00.00.G04-KQ004641",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71bc-74dd-9d15-7dfb95a99b22",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "isProcessingResult": false,
            "name": "+ Giấy tờ chứng minh được phép hoạt động và có trụ sở tại Việt Nam đối với tổ chức nước ngoài hoặc giấy tờ chứng minh được phép cư trú tại Việt Nam đối với cá nhân nước ngoài.",
            "code": "000.00.00.G04-KQ004640",
            "attachments": []
          }
        ]
      },
      {
        "name": "Giấy tờ phải nộp, gồm:",
        "profileComponents": [
          {
            "profileComponentId": "019d2bb8-71bc-74dd-9d15-6a0b0e63a41b",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "isProcessingResult": false,
            "name": "+ Đơn đề nghị đăng ký phương tiện theo Mẫu;",
            "code": "000.00.00.G04-KQ004635",
            "attachments": [
              {
                "id": "019d9600-0274-737d-8c18-c2ae36f3b30d",
                "fileName": "Mẫu đơn đề nghị ĐĂNG KÝ PHƯƠNG TIỆN VUI CHƠI GIẢI TRÍ DƯỚI NƯỚC.docx",
                "bucketName": "dvc",
                "filePath": "configuring/019d9600-0274-737d-8c18-c2ae36f3b30d/Mẫu đơn đề nghị ĐĂNG KÝ PHƯƠNG TIỆN VUI CHƠI GIẢI TRÍ DƯỚI NƯỚC.docx"
              }
            ]
          },
          {
            "profileComponentId": "019d2bb8-71bc-74dd-9d15-6ed6f3435c57",
            "originalQty": 1,
            "copyQty": 1,
            "required": false,
            "hasElectronicForm": false,
            "isProcessingResult": false,
            "name": "+ Biên lai nộp lệ phí trước bạ (bản chính hoặc bản điện tử hoặc bản sao điện tử) đối với phương tiện thuộc diện phải nộp lệ phí trước bạ.",
            "code": "000.00.00.G04-KQ004636",
