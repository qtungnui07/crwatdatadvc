    "codeNotation": "2.000755",
    "executionSteps": [
      {
        "name": "Bước 1. Lập, nộp hồ sơ",
        "description": "Người hưởng lập hồ sơ theo quy định tại mục 11.3 (Thành phần hồ sơ) và nộp cho cơ quan BHXH nơi đang chi trả lương hưu, trợ cấp BHXH hàng tháng.\n"
      },
      {
        "name": "Bước 2.",
        "description": "Cơ quan BHXH tiếp nhận hồ sơ và giải quyết theo quy định.\n"
      },
      {
        "name": "Bước 3. Nhận kết quả giải quyết",
        "description": "Người hưởng nhận Quyết định về việc hưởng trợ cấp một lần và tiền trợ cấp.\n"
      }
    ],
