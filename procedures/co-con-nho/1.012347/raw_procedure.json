    "description": "",
    "name": "Gia hạn giấy phép đặt văn phòng đại diện nước ngoài tại Việt Nam.",
    "decisionNo": "",
    "executionCases": [
      {
        "name": "",
        "profileComponents": [
          {
            "profileComponentId": "019d2bb8-71ae-70d7-bd68-600c4e61693f",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Văn bản báo cáo về hoạt động hợp tác với cơ quan, tổ chức trong lĩnh vực kinh doanh bảo hiểm tại Việt Nam của văn phòng đại diện nước ngoài tại Việt Nam hoặc doanh nghiệp nước ngoài.",
            "code": "000.00.00.G12-KQ012950",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71ae-70d7-bd68-5d5ea61056f6",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Sơ yếu lý lịch, bản sao thẻ căn cước công dân hoặc giấy chứng minh nhân dân hoặc hộ chiếu của người dự kiến giữ chức danh Trưởng văn phòng đại diện (nếu có thay đổi). Khi các loại giấy tờ về lai lịch, nhân dạng của công dân Việt Nam thuộc thành phần hồ sơ quy định tại Nghị định này đã được tích hợp trong Cơ sở dữ liệu quốc gia về dân cư, Cơ sở dữ liệu căn cước công dân thì Bộ Tài chính có trách nhiệm khai thác và sử dụng thông tin trong Cơ sở dữ liệu quốc gia về dân cư, Cơ sở dữ liệu căn cước công dân trên cơ sở trao đổi, cung cấp thông tin giữa các cơ quan quản lý nhà nước.",
            "code": "000.00.00.G12-KQ012949",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71ae-70d7-bd68-5b10c32738fa",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Bản sao báo cáo tài chính đã được kiểm toán bởi tổ chức kiểm toán độc lập của doanh nghiệp nước ngoài trong 03 năm liền kề năm nộp hồ sơ đề nghị gia hạn;",
            "code": "000.00.00.G12-KQ012948",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71ae-70d7-bd68-50ec68ce9715",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Văn bản đề nghị gia hạn hoạt động của văn phòng đại diện theo mẫu quy định tại Phụ lục XIII ban hành kèm theo Nghị định này;",
            "code": "000.00.00.G12-KQ012946",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71ae-70d7-bd68-65b211a2e207",
            "originalQty": 0,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "Ghi chú: 01 bản tiếng Việt và 01 bản tiếng Anh; Khi các loại giấy tờ về lai lịch, nhân dạng của công dân Việt Nam thuộc thành phần hồ sơ quy định tại Nghị định này đã được tích hợp trong Cơ sở dữ liệu quốc gia về dân cư, Cơ sở dữ liệu căn cước công dân thì Bộ Tài chính có trách nhiệm khai thác và sử dụng thông tin trong Cơ sở dữ liệu quốc gia về dân cư, Cơ sở dữ liệu căn cước công dân trên cơ sở trao đổi, cung cấp thông tin giữa các cơ quan quản lý nhà nước.",
            "code": "000.00.00.G12-KQ012951",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71ae-70d7-bd68-554144256d2b",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Bản sao giấy phép thành lập hoặc giấy chứng nhận đăng ký kinh doanh hoặc tài liệu tương đương khác;",
            "code": "000.00.00.G12-KQ012947",
            "attachments": []
          }
        ]
      }
    ],
