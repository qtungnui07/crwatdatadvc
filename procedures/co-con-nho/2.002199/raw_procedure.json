            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "Cơ quan chủ quản xác nhận chuyên gia theo đúng mẫu quy định  trong vòng 15 làm việc kể từ ngày  nhận đủ hồ sơ hợp lệ.",
            "code": "000.00.00.G05-KQ1869",
            "attachments": []
          }
        ]
      }
