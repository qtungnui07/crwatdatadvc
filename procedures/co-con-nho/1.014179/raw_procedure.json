    "description": "",
    "name": "HƯỞNG TRỢ CẤP TUẤT MỘT LẦN",
    "decisionNo": "",
    "executionCases": [
      {
        "name": "-  Đối với thân nhân của người đang hưởng lương hưu hoặc đang tạm dừng hưởng lương hưu hoặc trợ cấp tai nạn lao động, bệnh nghề nghiệp hằng tháng đã nghỉ việc bao gồm:",
        "profileComponents": [
          {
            "profileComponentId": "019d2bb8-71a4-7771-a050-470a2aa07819",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Biên bản giám định mức suy giảm khả năng lao động của Hội đồng giám định y khoa hoặc bản sao giấy xác nhận mức độ khuyết tật đặc biệt nặng có thể hiện kết luận của Hội đồng giám định y khoa ghi rõ tỷ lệ phần trăm suy giảm khả năng lao động đối với thân nhân bị suy giảm khả năng lao động từ 81% trở lên,",
            "code": "G09-KQ003018",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71a4-7771-a050-3c0390a48ba8",
            "originalQty": 0,
            "copyQty": 1,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Bản sao giấy chứng tử hoặc trích lục khai tử hoặc bản sao giấy báo tử hoặc bản sao quyết định của Toà án tuyên bố là đã chết;",
            "code": "G09-KQ003016",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71a4-7771-a050-40132a308903",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Tờ khai của thân nhân ,",
            "code": "G09-KQ003017",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71a4-7771-a050-4abda9ab29f1",
            "originalQty": 1,
            "copyQty": 1,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "⃰ Trường hợp người lao động là công dân nước ngoài làm việc tại Việt Nam chết tại nước ngoài thì bản sao giấy chứng tử hoặc trích lục khai tử hoặc bản sao giấy báo tử hoặc bản sao quyết định của Tòa án tuyên bố là đã chết được thay thế bằng bản dịch tiếng Việt được công chứng hoặc chứng thực theo quy định của pháp luật về công chứng, chứng thực các giấy tờ do cơ quan có thẩm quyền ở nước ngoài cấp thể hiện thông tin về người lao động là công dân nước ngoài chết (họ và tên, thời điểm chết, nơi chết)",
            "code": "G09-KQ003019",
            "attachments": []
          }
        ]
      },
      {
        "name": "- Đối với thân nhân của người đang tham gia bảo hiểm xã hội, đang bảo lưu thời gian đóng bảo hiểm xã hội bao gồm:",
        "profileComponents": [
          {
            "profileComponentId": "019d2bb8-71a4-7771-a050-35cb3b92112b",
            "originalQty": 1,
            "copyQty": 1,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Bản chính hoặc bản sao biên bản điều tra tai nạn lao động đối với trường hợp chết do tai nạn lao động; bản sao bệnh án điều trị bệnh nghề nghiệp đối với trường hợp chết do bệnh nghề nghiệp (trừ trường hợp người lao động đang tham gia bảo hiểm xã hội tự nguyện)",
