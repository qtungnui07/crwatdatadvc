    "executionSteps": [
      {
        "name": "a) Nộp hồ sơ TTHC:",
        "description": "- Trước khi đưa bến khách ngang sông, bến thủy nội địa phục vụ thi công công trình chính vào khai thác, chủ bến nộp hồ sơ đến Ủy ban nhân dân cấp xã.\n"
      },
      {
        "name": "b) Giải quyết TTHC:",
        "description": "- Trong thời hạn 05 ngày làm việc, kể từ ngày nhận đủ hồ sơ theo quy định, Ủy ban nhân dân cấp xã ban hành quyết định công bố hoạt động bến khách ngang sông, bến thủy nội địa phục vụ thi công công trình chính.\n"
      }
    ],
