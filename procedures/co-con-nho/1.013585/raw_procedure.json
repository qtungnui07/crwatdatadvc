{
  "id": "019d2bfb-a8ec-751d-b0a0-7f707740568c",
  "code": "1.013585",
  "name": "Thủ tục biên đối với tàu thuyền buồm, tàu thuyền thể thao, du thuyền, người đi trên tàu thuyền buồm, tàu thuyền thể thao, du thuyền nhập cảnh, xuất cảnh, tại cửa khẩu cảng",
  "detail": {
    "id": "019d2bfb-a8ec-751d-b0a0-7f707740568c",
    "code": "1.013585",
    "codeNotation": "1.013585",
    "executionSteps": [
      {
        "name": "",
        "description": "- Bước 1: Chậm nhất 02 giờ, kể từ khi tàu thuyền neo đậu tại cầu cảng; chậm nhất 04 giờ, kể từ khi tàu thuyền neo đậu tại các vị trí khác trong vùng nước cảng, người làm thủ tục phải nộp và xuất trình cho Biên phòng cửa khẩu cảng các loại giấy tờ đối với tàu thuyền nhập cảnh, hồ sơ chuyển cảng đối với tàu thuyền chuyển cảng đến theo quy định;\nChậm nhất 02 giờ, trước khi tàu thuyền dự kiến rời cảng, người làm thủ tục phải nộp và xuất trình cho Biên phòng cửa khẩu cảng các loại giấy tờ đối với tàu thuyền xuất cảnh, tàu thuyền chuyển cảng đi theo quy định;\n- Bước 2: Biên phòng cửa khẩu cảng kiểm tra tính hợp pháp, hợp lệ của các giấy tờ mà người làm thủ tục nộp và xuất trình; hoàn thành thủ tục nhập cảnh, xuất cảnh, chuyển cảng."
      }
    ],
    "executionMethods": [
      {
        "submissionMethod": "DIRECT",
        "processingTime": 1,
        "processingTimeUnit": "HOUR",
        "description": "Người làm thủ tục nộp, xuất trình các loại giấy tờ tại trụ sở Cảng vụ hàng hải, Cảng vụ đường thủy nội địa hoặc văn phòng đại diện Cảng vụ hàng hải, Cảng vụ đường thủy nội địa\nChậm nhất 01 giờ kể từ khi Biên phòng cửa khẩu cảng tiếp nhận đầy đủ các loại giấy tờ do người làm thủ tục nộp và xuất trình đối với tàu nhập cảnh, xuất cảnh, chuyển cảng đi;\n- Chậm nhất 30 phút kể từ khi Biên phòng cửa khẩu cảng tiếp nhận hồ sơ chuyển cảng đối với tàu chuyển cảng đến",
        "fees": [
          {
            "type": "FEE",
            "value": 0,
