{
  "id": "019df1bb-a259-77d4-be44-84dbd23cd11e",
  "code": "6.003632",
  "name": "Mua nhà ở thương mại để làm nhà ở phục vụ tái định cư",
  "detail": {
    "id": "019df1bb-a259-77d4-be44-84dbd23cd11e",
    "code": "6.003632",
    "codeNotation": "6.003632",
    "executionSteps": [
      {
        "name": "",
        "description": "+ Đơn vị được Ủy ban nhân dân cấp tỉnh giao bố trí nhà ở phục vụ tái định cư có\ntrách nhiệm xác định dự án đầu tư xây dựng nhà ở thương mại trên địa bàn để\nmua nhà ở thương mại làm nhà ở phục vụ tái định cư và lập phương án mua nhà\nở để báo cáo Sở Xây dựng nơi có nhà ở đó thẩm định;\n"
      },
      {
        "name": "",
        "description": "+ Trong thời hạn tối đa 30 ngày, kể từ ngày nhận được văn bản đề nghị của đơn\nvị được giao bố trí tái định cư kèm theo phương án mua nhà ở, Sở Xây dựng có\ntrách nhiệm chủ trì, phối hợp với cơ quan tài chính, tài nguyên và môi trường cấp\ntỉnh thẩm định để trình Ủy ban nhân dân cấp tỉnh phê duyệt phương án;\n"
      },
      {
        "name": "",
        "description": "+ Trong thời hạn tối đa 15 ngày, kể từ ngày Ủy ban nhân dân cấp tỉnh phê duyệt\nphương án mua nhà ở."
      }
    ],
