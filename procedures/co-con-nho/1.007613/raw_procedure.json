        "profileComponents": [
          {
            "profileComponentId": "019d2bb8-71b4-7308-810e-3f740dc0d0d0",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Hồ sơ hỗ trợ 20% định mức lao động chung: Định mức lao động chung để giao khoán hoặc trả công cho lao động do cơ quan có thẩm quyền quyết định, danh sách lao động là người dân tộc thiểu số có mặt thường xuyên trong năm quyết toán.",
            "code": "000.00.00.G12-KQ7674",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71b4-7308-810e-35df03eb2053",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Hồ sơ hỗ trợ kinh phí đào tạo: \tTrường hợp đào tạo tập trung tại các trường lớp dạy nghề: Hợp đồng đào tạo, thanh lý hợp đồng, chứng từ thanh toán tiền giữa đơn vị với các trường lớp dạy nghề. \tTrường hợp đào tạo tại đơn vị: Quyết định của đơn vị tổ chức lớp học, số người đào tạo, ngành, nghề đào tạo, các chứng từ thanh toán liên quan đến việc tổ chức lớp học.",
            "code": "000.00.00.G12-KQ7672",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71b4-7308-810e-3a6d3df27c35",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+  Hồ sơ hỗ trợ kinh phí đóng bảo hiểm: Danh sách lao động là người dân tộc thiểu số, mức đóng bảo hiểm xã hội, bảo hiểm y tế, bảo hiểm thất nghiệp có xác nhận của cơ quan bảo hiểm.",
            "code": "000.00.00.G12-KQ7673",
            "attachments": []
          }
        ]
      }
    ],
