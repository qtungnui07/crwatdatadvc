    "executionSteps": [
      {
        "name": "Nộp hồ sơ TTHC:",
        "description": "Tổ chức, cá nhân gửi trực tiếp hoặc gửi qua hệ thống bưu chính hoặc qua hệ thống dịch vụ công trực tuyến đến Ủy ban nhân dân cấp xã 01 bản chính hoặc biểu mẫu điện tử đơn đề nghị theo Mẫu.\n"
      },
      {
        "name": "Giải quyết TTHC:",
        "description": "Chậm nhất 02 ngày làm việc, kể từ ngày nhận được đơn đề nghị, Ủy ban nhân dân cấp xã ra quyết định công bố đóng, không cho phép hoạt động tại vùng nước khác không thuộc vùng nước trên tuyến đường thủy nội địa, vùng nước cảng biển hoặc khu vực hàng hải, được đánh dấu, xác định vị trí bằng phao hoặc cờ hiệu có màu sắc dễ quan sát.\n"
      }
    ],
