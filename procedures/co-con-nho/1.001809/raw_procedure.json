{
  "id": "019d2bfd-b54b-707a-965b-b91834d8aabf",
  "code": "1.001809",
  "name": "Thủ tục cấp giấy phép triển lãm mỹ thuật (thẩm quyền của Ủy ban nhân dân cấp tỉnh)",
  "detail": {
    "id": "019d2bfd-b54b-707a-965b-b91834d8aabf",
    "code": "1.001809",
    "codeNotation": "1.001809",
    "executionSteps": [
      {
        "name": "",
        "description": "- Tổ chức, cá nhân đề nghị cấp phép triển lãm mỹ thuật trong các trường hợp dưới đây gửi trực tiếp hoặc qua đường bưu điện 01 bộ hồ sơ đề nghị cấp phép đến Ủy ban nhân dân cấp tỉnh:\n+ Triển lãm mỹ thuật tại địa phương do cơ quan, tổ chức thuộc địa phương, cá nhân, nhóm cá nhân người Việt Nam hoặc người nước ngoài tổ chức;\n+ Đưa tác phẩm mỹ thuật Việt Nam ra nước ngoài triển lãm không mang danh nghĩa đại diện cho quốc gia Việt Nam.\n- Trong thời hạn 07 ngày làm việc kể từ ngày nhận đầy đủ hồ sơ hợp lệ, Ủy ban nhân dân cấp tỉnh cấp giấy phép, trường hợp không cấp giấy phép phải có văn bản trả lời, nêu rõ lý do.\n"
      }
    ],
    "executionMethods": [
      {
        "submissionMethod": "POSTAL",
        "processingTime": 7,
        "processingTimeUnit": "WORKING_DAY",
        "fees": [
