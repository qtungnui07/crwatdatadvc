            "required": false,
            "hasElectronicForm": false,
            "isProcessingResult": false,
            "name": "4. Biên bản giám định mức suy giảm KNLĐ lần trước gần nhất của Hội đồng GĐYK đối với trường hợp đã được giám định nhưng không đủ điều kiện về mức suy giảm KNLĐ để hưởng trợ cấp.",
            "code": "000.00.00.G24-KQ0260",
