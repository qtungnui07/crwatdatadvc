    "codeNotation": "1.005193",
    "executionSteps": [
      {
        "name": "Nộp hồ sơ thủ tục hành chính",
        "description": "Người đề nghị sửa chữa, bổ sung, điều chỉnh thông tin về đăng ký quốc tịch tàu bay, đăng ký các quyền đối với tàu bay và đăng ký văn bản IDERA gửi hồ sơ đề nghị sửa chữa, bổ sung, điều chỉnh thông tin trực tiếp, qua hệ thống bưu chính hoặc các hình thức phù hợp khác đến Cục Hàng không Việt Nam.\n"
      },
      {
        "name": "Giải quyết thủ tục hành chính",
        "description": "Người đề nghị sửa chữa, bổ sung, điều chỉnh thông tin về đăng ký quốc tịch tàu bay, đăng ký các quyền đối với tàu bay và đăng ký văn bản IDERA gửi hồ sơ đề nghị sửa chữa, bổ sung, điều chỉnh thông tin trực tiếp, qua hệ thống bưu chính hoặc trên môi trường điện tử hoặc bằng các hình thức khác đến Cục Hàng không Việt Nam.\n"
      }
    ],
