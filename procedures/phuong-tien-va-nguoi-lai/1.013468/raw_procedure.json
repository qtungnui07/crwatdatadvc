    "executionSteps": [
      {
        "name": "a) Nộp hồ sơ TTHC:",
        "description": "Tổ chức khai thác hoạt động tàu lặn gửi trên Cổng Dịch vụ công quốc gia hoặc qua hệ thống bưu chính hoặc trực tiếp đến Sở Xây dựng 01 bản chính hoặc biểu mẫu điện tử Đơn đề nghị chấm dứt hoạt động tàu lặn."
      },
      {
        "name": "b) Giải quyết TTHC:",
        "description": "Trong thời hạn 02 ngày làm việc, kể từ ngày nhận được đơn đề nghị, Sở Xây dựng ra quyết định chấm dứt hoạt động tàu lặn theo mẫu."
      }
    ],
