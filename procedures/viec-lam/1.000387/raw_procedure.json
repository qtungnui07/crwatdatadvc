    "executionSteps": [
      {
        "name": "",
        "description": "- Ủy ban nhân dân cấp tỉnh tiếp nhận Hồ sơ đề nghị cấp lại Giấy chứng nhận đủ điều kiện thương nhân xuất khẩu, nhập khẩu CNG của thương nhân;\n- Trong thời gian 07 ngày làm việc kể từ ngày nhận được hồ sơ đầy đủ và hợp lệ, Ủy ban nhân dân cấp tỉnh có trách nhiệm cấp lại Giấy chứng nhận đủ điều kiện cho thương nhân;\n- Thời hạn hiệu lực của Giấy chứng nhận không thay đổi.\n"
      }
    ],
