    "name": "Đăng ký chào bán trái phiếu ra công chúng bằng đồng Việt Nam của tổ chức tài chính quốc tế",
    "decisionNo": "",
    "executionCases": [
      {
        "name": "",
        "profileComponents": [
          {
            "profileComponentId": "019d2bb8-71af-7518-a305-08ba79e6c3d3",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Quyết định của cấp có thẩm quyền của tổ chức phát hành thông qua phương án phát hành và phương án sử dụng vốn thu được từ đợt chào bán.",
            "code": "000.00.00.G12-KQ015111",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71af-7518-a305-05c070a9584b",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Bản công bố thông tin về đợt chào bán trái phiếu ra công chúng tại Việt Nam của tổ chức tài chính quốc tế theo Mẫu số 07B Phụ lục ban hành kèm theo Nghị định số 245/2025/NĐ-CP sửa đổi, bổ sung một số điều của Nghị định số 155/2020/NĐ-CP.",
            "code": "000.00.00.G12-KQ015110",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71ab-713b-a9fb-e1a486e4f9ac",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Văn bản cam kết thực hiện các nghĩa vụ của tổ chức phát hành đối với các nhà đầu tư về điều kiện phát hành, thanh toán, bảo đảm quyền và lợi ích hợp pháp của nhà đầu tư và các điều kiện khác.",
            "code": "000.00.00.G12-KQ010449",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71af-7518-a305-02afb45429a0",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Giấy đăng ký chào bán ra công chúng tại Việt Nam của tổ chức tài chính quốc tế theo Mẫu số 07A Phụ lục ban hành kèm theo Nghị định số 245/2025/NĐ-CP sửa đổi, bổ sung một số điều của Nghị định số 155/2020/NĐ-CP.",
            "code": "000.00.00.G12-KQ015109",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71af-7518-a305-0f40a0e74916",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Văn bản cam kết niêm yết trái phiếu sau khi kết thúc đợt chào bán.",
            "code": "000.00.00.G12-KQ015112",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71af-7518-a305-12f16f918f12",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Văn bản xác nhận của ngân hàng, chi nhánh ngân hàng nước ngoài về việc tổ chức phát hành mở tài khoản phong tỏa nhận tiền mua trái phiếu của đợt chào bán.",
            "code": "000.00.00.G12-KQ015113",
            "attachments": []
          }
        ]
      }
