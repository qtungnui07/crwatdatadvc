    "description": "",
    "name": "Đăng ký chào bán cổ phiếu ra công chúng của cổ đông công ty đại chúng",
    "decisionNo": "",
    "executionCases": [
      {
        "name": "",
        "profileComponents": [
          {
            "profileComponentId": "019d2bb8-71ab-713b-a9fb-874f2e2b320a",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Hợp đồng tư vấn hồ sơ đăng ký chào bán cổ phiếu ra công chúng với công ty chứng khoán, ngoại trừ trường hợp cổ đông đăng ký chào bán là công ty chứng khoán;",
            "code": "000.00.00.G12-KQ010426",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71af-7518-a303-c76a4c270463",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Văn bản chấp thuận của Ngân hàng Nhà nước Việt Nam, Bộ Tài chính về việc cổ đông chuyển nhượng cổ phiếu (nếu có)",
            "code": "000.00.00.G12-KQ015031",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71ab-713b-a9fb-7f4a6d1ef637",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Quyết định của cấp có thẩm quyền của cổ đông đăng ký chào bán là tổ chức thông qua phương án chào bán, trong đó bao gồm: loại cổ phiếu chào bán; số lượng cổ phiếu chào bán; giá chào bán hoặc nguyên tắc xác định giá chào bán hoặc ủy quyền xác định giá chào bán;",
            "code": "000.00.00.G12-KQ010424",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71ab-713b-a9fb-7a2aa14ee7b2",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Bản cáo bạch theo quy định tại Điều 19 Luật Chứng khoán;",
            "code": "000.00.00.G12-KQ010423",
            "attachments": [
              {
                "id": "019e80f9-1423-71c3-b145-fd8555246c87",
                "fileName": "Phụ lục số 01.docx",
                "bucketName": "dvc",
                "filePath": "configuring/019e80f9-1423-71c3-b145-fd8555246c87/Phụ lục số 01.docx"
              }
            ]
          },
          {
            "profileComponentId": "019d2bb8-71af-7518-a302-e4f9f0595b58",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Giấy đăng ký chào bán theo Mẫu số 06 Phụ lục ban hành kèm theo Nghị định 155/2020/NĐ-CP",
            "code": "000.00.00.G12-KQ014976",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71af-7518-a303-c0a2cab045d4",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Quyết định của cấp có thẩm quyền của cổ đông đăng ký chào bán là tổ chức thông qua phương án đảm bảo việc chào bán cổ phiếu đáp ứng quy định về tỷ lệ sở hữu nước ngoài tại công ty đại chúng có cổ phiếu được chào bán;",
            "code": "000.00.00.G12-KQ015030",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71af-7518-a302-f1d9081e6972",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Văn bản xác nhận của ngân hàng, chi nhánh ngân hàng nước ngoài về việc cổ đông đăng ký chào bán mở tài khoản phong tỏa nhận tiền mua cổ phiếu của đợt chào bán;",
            "code": "000.00.00.G12-KQ014979",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71af-7518-a302-ed090f59714b",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Báo cáo tài chính trong 02 năm gần nhất của tổ chức có cổ phiếu được chào bán theo quy định tại Điều 20 Luật Chứng khoán, trong đó trường hợp cổ đông đăng ký chào bán hoàn thiện hồ sơ sau 90 ngày kể từ ngày kết thúc kỳ kế toán năm, cổ đông đăng ký chào bán phải bổ sung báo cáo tài chính năm gần nhất được kiểm toán của tổ chức có cổ phiếu được chào bán",
            "code": "000.00.00.G12-KQ014978",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71af-7518-a302-e93b05639ffa",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Sổ đăng ký cổ đông hoặc giấy xác nhận của Tổng công ty lưu ký và bù trừ chứng khoán Việt Nam hoặc của thành viên lưu ký hoặc giấy chứng nhận sở hữu cổ phần;",
            "code": "000.00.00.G12-KQ014977",
            "attachments": []
          }
        ]
      }
    ],
