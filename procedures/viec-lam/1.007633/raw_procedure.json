            "required": false,
            "hasElectronicForm": false,
            "isProcessingResult": false,
            "name": "3/ Danh sách kiểm toán viên hành nghề có hợp đồng lao động làm toàn bộ thời gian tại doanh nghiệp (theo mẫu quy định tại Phụ lục III).",
            "code": "000.00.00.G12-KQ7765",
