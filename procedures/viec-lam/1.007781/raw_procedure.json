        "profileComponents": [
          {
            "profileComponentId": "019d2bb8-71b6-776e-8abf-017a77bfc635",
            "originalQty": 0,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Giấy chứng nhận đăng ký kinh doanh (hoặc Giấy chứng nhận Đầu tư; Giấy chứng nhận thành lập doanh nghiệp; hoặc các Giấy tờ khác có giá trị tương đương quy định về việc thành lập doanh nghiệp): 01 bản chụp từ bản chính (có xác nhận, ký tên, đóng dấu của người nộp thuế);",
            "code": "000.00.00.G12-KQ8624",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71b6-776e-8abf-05418ae9f9ab",
            "originalQty": 0,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Giấy chứng nhận đăng ký mã số thuế: 01 bản chụp từ bản chính (có xác nhận, ký tên, đóng dấu của người nộp thuế) (Trường hợp khai thác được thông tin trong Cơ sở dữ liệu quốc gia về đăng ký doanh nghiệp: Tổ chức, cá nhân, doanh nghiệp không phải nộp Bản sao Giấy chứng nhận đăng ký doanh nghiệp). ;",
            "code": "000.00.00.G12-KQ8625",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71b6-776e-8abf-0bbaf74961af",
            "originalQty": 0,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Tài liệu khác có liên quan đến nội dung xác nhận: 01 bản chụp từ bản chính (có xác nhận, ký tên, đóng dấu của người nộp thuế);",
            "code": "000.00.00.G12-KQ8626",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71b6-776e-8abe-fefbe7e09617",
            "originalQty": 0,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Văn bản đề nghị xác nhận hoàn thành nghĩa vụ nộp thuế do người đại diện theo pháp luật của doanh nghiệp ký, đóng dấu (trường hợp người đại diện theo uỷ quyền ký thì phải có giấy uỷ quyền của người đại diện theo pháp luật) (01 bản chính), trong đó có các nội dung: ++ Tên người nộp thuế, mã số thuế; ++ Nội dung, mục đích, yêu cầu xác nhận; ++ Tài liệu chứng minh nội dung yêu cầu xác nhận (bản chụp).",
            "code": "000.00.00.G12-KQ8623",
            "attachments": []
          }
        ]
      }
    ],
