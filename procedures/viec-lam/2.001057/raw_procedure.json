{
  "id": "019d2bfd-fba4-7418-b25f-dffe1efcdb54",
  "code": "2.001057",
  "name": "Thủ tục công nhận Ban vận động thành lập hội thể thao quốc gia",
  "detail": {
    "id": "019d2bfd-fba4-7418-b25f-dffe1efcdb54",
    "code": "2.001057",
    "codeNotation": "2.001057",
    "executionSteps": [
      {
        "name": "",
        "description": " Tổng cục Thể dục thể thao tiếp nhận, thẩm định hồ sơ đề nghị công nhận Ban vận động thành lập hội thể thao quốc gia.\n\nTrong thời hạn 30 (ba mươi) ngày làm việc, kể từ ngày nhận hồ sơ đầy đủ, hợp pháp, Tổng cục Thể dục thể thao có trách nhiệm trình Bộ Văn hóa, Thể thao và Du lịch xem xét, quyết định công nhận Ban vận động thành lập hội thể thao quốc gia; trong trường hợp không đồng ý phải có văn bản trả lời và nêu rõ lý do.\n"
      }
    ],
    "executionMethods": [
      {
        "submissionMethod": "DIRECT",
        "processingTime": 30,
