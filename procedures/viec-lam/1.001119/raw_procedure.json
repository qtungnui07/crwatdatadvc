    "executionSteps": [
      {
        "name": "Nộp hồ sơ",
        "description": "Cơ quan báo chí nước ngoài có yêu cầu lập Văn phòng thường trú tại Việt Nam gửi hồ sơ tới Bộ Ngoại giao hoặc cơ quan đại diện Việt Nam ở nước ngoài.\t\n"
      },
      {
        "name": "Thẩm định hồ sơ",
        "description": "Bộ Ngoại giao thẩm định hồ sơ và cấp Giấy phép lập Văn phòng thường trú tại Việt Nam cho cơ quan báo chí nước ngoài nếu được chấp thuận.\t\n"
      },
      {
        "name": "Nhận Giấy phép",
        "description": "Phóng viên thường trú của Văn phòng thường trú đến Bộ Ngoại giao nhận Giấy phép mở văn phòng báo chí thường trú tại Việt Nam (trong vòng 30 ngày kể từ khi nhận được thông báo chấp thuận).\t\n"
      }
    ],
