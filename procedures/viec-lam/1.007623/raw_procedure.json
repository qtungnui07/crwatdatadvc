            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+  Hồ sơ hỗ trợ kinh phí đóng bảo hiểm: Danh sách lao động là người dân tộc thiểu số, mức đóng bảo hiểm xã hội, bảo hiểm y tế, bảo hiểm thất nghiệp có xác nhận của cơ quan bảo hiểm.",
            "code": "000.00.00.G12-KQ7724",
