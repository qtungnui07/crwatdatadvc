    "executionSteps": [
      {
        "name": "Bước 1. Lập, nộp hồ sơ",
        "description": "NLĐ lập hồ sơ theo quy định tại mục 9.3 (Thành phần hồ sơ) và nộp cho cơ quan BHXH.\n"
      },
      {
        "name": "Bước 2.",
        "description": "Cơ quan BHXH tiếp nhận hồ sơ và giải quyết theo quy định.\n"
      },
      {
        "name": "Bước 3. Nhận kết quả giải quyết",
        "description": "NLĐ nhận kết quả giải quyết, gồm: Quyết định về việc hưởng BHXH một lần; Bản quá trình đóng BHXH; Tiền trợ cấp.\n"
      }
    ],
