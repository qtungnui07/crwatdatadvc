    ],
    "description": "",
    "name": "Đăng ký phương pháp trích lập dự phòng nghiệp vụ.",
    "decisionNo": "",
    "executionCases": [
      {
        "name": "",
        "profileComponents": [
          {
            "profileComponentId": "019d2bb8-71ae-70d7-bd69-39f69f1f5f92",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Tài liệu giải trình và minh họa về các phương pháp, cơ sở trích lập dự phòng nghiệp vụ bảo hiểm dự kiến áp dụng có xác nhận của chuyên gia tính toán. Trường hợp thay đổi phương pháp, cơ sở trích lập dự phòng nghiệp vụ bảo hiểm, tài liệu giải trình phải chứng minh được phương pháp, cơ sở trích lập mới phản ánh chính xác, đầy đủ hơn so với phương pháp, cơ sở trích lập cũ về trách nhiệm của doanh nghiệp bảo hiểm, doanh nghiệp tái bảo hiểm, chi nhánh nước ngoài tại Việt Nam.",
            "code": "000.00.00.G12-KQ013003",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71ae-70d7-bd69-3634d70bd8fa",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Văn bản đăng ký hoặc thay đổi phương pháp, cơ sở trích lập dự phòng nghiệp vụ bảo hiểm theo mẫu quy định tại Phụ lục IX ban hành kèm theo Nghị định 46/2023/NĐ-CP",
            "code": "000.00.00.G12-KQ013002",
            "attachments": []
          }
        ]
      }
    ],
