    "decisionNo": "",
    "executionCases": [
      {
        "name": "- Văn bản chấp thuận việc nhà đầu tư đề xuất dự án gồm các nội dung sau:",
        "profileComponents": [
          {
            "profileComponentId": "019d2bb8-71af-7518-a301-25d89f106a54",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Thời hạn, địa điểm nộp hồ sơ đề xuất dự án; cơ quan, đơn vị tiếp nhận hồ sơ của nhà đầu tư;",
            "code": "000.00.00.G12-KQ014865",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71af-7518-a301-283d70f2a9fc",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Quy định về trách nhiệm của nhà đầu tư chịu mọi chi phí, rủi ro trong trường hợp hồ sơ đề xuất dự án không được chấp thuận và nguyên tắc xử lý trong trường hợp nhà đầu tư đề xuất dự án không được lựa chọn;",
            "code": "000.00.00.G12-KQ014866",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71af-7518-a301-2f453d13dda6",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Trách nhiệm, cách thức phối hợp của các cơ quan có liên quan trong việc hướng dẫn nhà đầu tư lập hồ sơ đề xuất dự án;",
            "code": "000.00.00.G12-KQ014867",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71af-7518-a301-200589d887c0",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Tên nhà đầu tư lập hồ sơ đề xuất dự án;",
            "code": "000.00.00.G12-KQ014864",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71af-7518-a301-3006586c1a88",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "source": "",
            "name": "+ Các nội dung khác có liên quan.",
            "code": "000.00.00.G12-KQ014868",
            "attachments": []
          }
        ]
      }
    ],
