{
  "id": "019d84cc-346b-761d-81a0-e21b5b938a48",
  "code": "1.014964",
  "name": "Thủ tục nhập cảnh, xuất cảnh, chuyển cảng đối với tàu quân sự nước ngoài đến lãnh hải, khu vực nội thuỷ ngoài vùng nước cảng biển.",
  "detail": {
    "id": "019d84cc-346b-761d-81a0-e21b5b938a48",
    "code": "1.014964",
    "codeNotation": "1.014964",
    "executionSteps": [
      {
        "name": "",
        "description": "Bước 1: Sau khi tàu quân sự nước ngoài đến lãnh hải, khu vực nội thuỷ ngoài vùng nước cảng biển, người làm thủ tục nộp, xuất trình các loại giấy tờ theo quy định cho các Cơ quan quản lý nhà nước chuyên ngành tại cảng (Biên phòng cửa khẩu cảng, Cảng vụ hàng hải, Hải quan cửa khẩu cảng, Kiểm dịch y tế quốc tế, kiểm dịch động, thực vật - nếu tàu phải kiểm dịch động vật, thực vật).\nBước 2: Các Cơ quan quản lý nhà nước chuyên ngành tại cảng kiểm tra, đăng ký, kiểm chứng nhập cảnh, xuất cảnh hoặc xác nhận nhập cảnh, xuất cảnh, chuyển cảng cho tàu, thành viên trên tàu."
      }
    ],
    "executionMethods": [
      {
        "submissionMethod": "DIRECT",
        "processingTime": 0,
        "processingTimeUnit": "OTHER",
        "description": "Thời hạn làm thủ tục nhập cảnh, xuất cảnh, chuyển cảng kết thúc khi người làm thủ tục nộp đầy đủ bản chính các loại giấy tờ theo quy định.\nNgười làm thủ tục khai báo, nộp các loại giấy tờ tại trụ sở Cảng vụ hàng hải thuộc cấp tỉnh nơi tàu đến.",
        "fees": [
          {
            "type": "FEE",
            "value": 0,
            "currencyId": "",
            "attachment": null,
            "description": ""
          }
        ]
      },
      {
        "submissionMethod": "DIRECT",
        "processingTime": 48,
        "processingTimeUnit": "HOUR",
        "description": "Người làm thủ tục khai báo, nộp các loại giấy tờ tại trụ sở Cảng vụ hàng hải thuộc cấp tỉnh nơi tàu đến.\nTrường hợp vì lý do khách quan không đủ thời gian để nộp bản chính các loại giấy tờ theo quy định, các cơ quan quản lý nhà nước chuyên ngành tại cảng cho phép người làm thủ tục gửi bản fax hoặc thư điện tử để làm thủ tục nhập cảnh, xuất cảnh. Trong thời hạn 48 (bốn tám) giờ, kể từ khi gửi bản fax hoặc thư điện tử, người làm thủ tục phải nộp bản chính.",
        "fees": [
          {
            "type": "FEE",
            "value": 0,
            "currencyId": "",
            "attachment": null,
            "description": ""
          }
        ]
      }
    ],
