    "executionCases": [
      {
        "name": "\t 1) Thành phần hồ sơ, bao gồm:",
        "profileComponents": [
          {
            "profileComponentId": "019d2bb8-71b3-76aa-8840-18809430c06d",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "isProcessingResult": false,
            "name": "c) Sơ yếu lý lịch có xác nhận của cơ quan, đơn vị nơi đang công tác hoặc Ủy ban nhân dân địa phương nơi cư trú;",
            "code": "000.00.00.G12-KQ6955",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71b1-7528-b106-7d70d7d3fb63",
            "originalQty": 1,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "isProcessingResult": false,
            "name": "a) Phiếu đăng ký dự thi có xác nhận của cơ quan, đơn vị nơi đang công tác hoặc của Ủy ban nhân dân địa phương nơi cư trú, có dán ảnh màu cỡ 3x4 và đóng dấu giáp lai theo mẫu quy định tại Phụ lục số 02a hoặc Phụ lục số 02b ban hành kèm theo Thông tư 91 kèm theo Giấy xác nhận về thời gian công tác thực tế làm tài chính, kế toán, kiểm toán có chữ ký của người đại diện theo pháp luật (hoặc người được ủy quyền) và đóng dấu xác nhận của cơ quan, đơn vị theo mẫu quy định tại Phụ lục số 06 ban hành kèm theo Thông tư này;",
            "code": "000.00.00.G12-KQ3461",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71b3-76aa-8840-1760050bd12b",
            "originalQty": 0,
            "copyQty": 1,
            "required": false,
            "hasElectronicForm": false,
            "isProcessingResult": false,
            "name": "b) Bản sao có chứng thực giấy chứng minh nhân dân hoặc thẻ căn cước hoặc hộ chiếu;",
            "code": "000.00.00.G12-KQ6954",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71b3-76aa-8840-1d5d91a6947f",
            "originalQty": 0,
            "copyQty": 1,
            "required": false,
            "hasElectronicForm": false,
            "isProcessingResult": false,
            "name": "d) Bản sao văn bằng, chứng chỉ theo quy định tại khoản 2 Điều 4 Thông tư 91, có xác nhận của tổ chức cấp hoặc cơ quan công chứng. Nếu là bằng tốt nghiệp đại học các chuyên ngành khác thì phải nộp kèm theo bảng điểm có chứng thực ghi rõ số đơn vị học trình (hoặc tiết học) của tất cả các môn học. Trường hợp người dự thi nộp bằng thạc sỹ, tiến sỹ thì phải nộp kèm theo bảng điểm học thạc sỹ, tiến sỹ có ghi rõ ngành học có chứng thực;",
            "code": "000.00.00.G12-KQ6956",
            "attachments": []
          },
          {
            "profileComponentId": "019d2bb8-71b3-76aa-8840-2337033d1ad3",
            "originalQty": 3,
            "copyQty": 0,
            "required": false,
            "hasElectronicForm": false,
            "isProcessingResult": false,
            "name": "đ) 3 ảnh màu cỡ 3x4cm mới chụp trong vòng 6 tháng và 02 phong bì có dán tem và ghi rõ họ, tên, địa chỉ của người nhận.",
            "code": "000.00.00.G12-KQ6957",
