    "codeNotation": "1.013836",
    "executionSteps": [
      {
        "name": "",
        "description": "- Văn phòng công chứng thuộc trường hợp quy định tại khoản 1 Điều 26 của Luật Công chứng lập 01 bộ hồ sơ theo quy định, nộp trực tiếp hoặc qua dịch vụ bưu chính hoặc trực tuyến trên môi trường điện tử về Sở Tư pháp nơi đăng ký hoạt động.\n\n- Trong thời hạn 05 ngày làm việc kể từ ngày nhận đủ hồ sơ hợp lệ, Sở Tư pháp ghi nhận nội dung thay đổi vào giấy đăng ký hoạt động của Văn phòng công chứng; trường hợp từ chối phải thông báo bằng văn bản có nêu rõ lý do."
      }
    ],
    "executionMethods": [
      {
